# ============================================================
# Vercel AI Gateway (PRIMARY — recommended)
# ============================================================
# Get your key from: Vercel Dashboard → AI Gateway → API Keys
# Docs: https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY="vgat_your_key_here"

# ============================================================
# Google Gemini API Key (FALLBACK for local dev without Gateway)
# ============================================================
# Get your key from: https://aistudio.google.com/app/apikey
# Only used if AI_GATEWAY_API_KEY is not set
GEMINI_API_KEY="your_gemini_api_key_here"

# ============================================================
# App URL (auto-injected on Vercel deployments)
# ============================================================
APP_URL="http://localhost:3000"
